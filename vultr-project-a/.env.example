# Copy this file to .env and fill values only on your machine or deployment host.
# Do not put secrets in VITE_* variables; Vite exposes those to the browser.

# Public frontend knob. This is not a secret.
VITE_API_BASE_URL=http://127.0.0.1:8765

# Deployment/status metadata. This is not a secret.
RECLAIM_DEPLOY_MODE=local

# Vultr provider credentials.
VULTR_API_KEY=
VULTR_SERVERLESS_INFERENCE_API_KEY=
VULTR_SERVERLESS_INFERENCE_BASE_URL=https://api.vultrinference.com/v1
VULTR_SERVERLESS_INFERENCE_MODEL=kimi-k2-instruct
VULTR_SERVERLESS_INFERENCE_TIMEOUT_SECONDS=12

# Vultr Object Storage is S3-compatible.
VULTR_OBJECT_STORAGE_ACCESS_KEY=
VULTR_OBJECT_STORAGE_SECRET_KEY=
VULTR_OBJECT_STORAGE_ENDPOINT=
VULTR_OBJECT_STORAGE_BUCKET=
VULTR_OBJECT_STORAGE_REGION=

# Optional future managed database connection.
DATABASE_URL=
