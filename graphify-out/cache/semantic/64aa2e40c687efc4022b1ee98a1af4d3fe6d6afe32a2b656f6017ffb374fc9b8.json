 cause, and action ranking are deterministic code; Crusoe only turns the result into a sentence with why-chips citing provided facts verbatim \u2014 pre-answering 'isn't the AI making up the safety numbers?'.", "source_file": "projects/track-3-crusoe/a/proposal.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "projects_track_3_crusoe_a_proposal_faa_part_107_35", "label": "FAA Part 107.35 Waiver (human abort call in federal law)", "file_type": "concept", "source_file": "projects/track-3-crusoe/a/proposal.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}], "edges": [{"source": "projects_track_3_crusoe_a_proposal_cluster_vs_isolated", "target": "projects_track_3_crusoe_a_proposal_air_boss", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "projects/track-3-crusoe/a/proposal.md", "source_location": null, "weight": 1.0}, {"source": "projects_track_3_crusoe_a_proposal_preference_table_learning", "target": "projects_track_3_crusoe_a_proposal_air_boss", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "projects/track-3-crusoe/a/proposal.md", "source_location": null, "weight": 1.0}, {"source": "projects_track_3_crusoe_a_proposal_llm_never_touches_numbers", "target": "projects_track_3_crusoe_a_proposal_air_boss", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "projects/track-3-crusoe/a/proposal.md", "source_location": null, "weight": 1.0}, {"source": "projects_track_3_crusoe_a_proposal_air_boss", "target": "projects_track_3_crusoe_a_proposal_crusoe_managed_inference", "relation": "calls", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "projects/track-3-crusoe/a/proposal.md", "source_location": null, "weight": 1.0}, {"source": "projects_track_3_crusoe_a_proposal_air_boss", "target": "projects_t