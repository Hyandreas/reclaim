{"nodes": [{"id": "projects_track_3_crusoe_c_proposal_firebreak", "label": "FIREBREAK (Wildland-Fire Incident-Commander Copilot)", "file_type": "concept", "source_file": "projects/track-3-crusoe/c/proposal.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "projects_track_3_crusoe_c_proposal_translation_latency_reframe", "label": "Translation-Latency Reframe (failure mode is not missing data)", "file_type": "rationale", "rationale": "On a fire the failure mode is translation latency \u2014 too many feeds and not enough trusted judgment delivered fast enough to act on; the deadliest event is a wind shift invalidating an escape route faster than radio chatter can track it (Yarnell Hill, 2013).", "source_file": "projects/track-3-crusoe/c/proposal.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "projects_track_3_crusoe_c_proposal_hazard_agnostic_margin_bias", "label": "Hazard-Agnostic Safety-Margin Bias (override learning that generalizes)", "file_type": "rationale", "rationale": "An override widens a per-crew safety margin that later triggers an earlier warning on an unrelated hazard type (spot fire, not front advance) \u2014 adaptation of a policy, not memorization of one fact; the one part a pattern-cloner doesn't get by copying the brief.", "source_file": "projects/track-3-crusoe/c/proposal.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "projects_track_3_crusoe_c_proposal_glass_box_override", "label": "Glass-Box Override (map-synced advisory pulse)", "file_type": "concept", "source_file": "projects/track-3-crusoe/c/proposal.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "projects_track_3_crusoe_c_proposal_fire_cellular_automaton", "label": "Fire-Spread Cellular Automaton (wind/fuel/slope weighted, Rothermel-grounded)", "file_type": "concept", "source_file": "projects/track-3-crusoe/c/proposal.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "projects_track_3_crusoe_c_proposal_situation_card", "label": "Single Situation Card (one map, one sentence, one tap)", "file_type": "concept", "source_file": "projects/track-3-crusoe/c/proposal.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "projects_track_3_crusoe_c_proposal_two_call_patterns", "label": "Two Crusoe Call Patterns (single-shot critical path vs function-calling Why path)", "file_type": "rationale", "rationale": "The timing-critical countdown path uses one JSON-mode request with pre-fetched state (zero tool round-trips gambled against the clock); genuine multi-step function-calling is reserved for the operator-initiated Why path where 2-3s is affordable.", "source_file": "projects/track-3-crusoe/c/proposal.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}], "edges": [{"source": "projects_track_3_crusoe_c_proposal_translation_latency_reframe", "target": "projects_track_3_crusoe_c_proposal_firebreak", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "projects/track-3-crusoe/c/proposal.md", "source_location": null, "weight": 1.0}, {"source": "projects_track_3_crusoe_c_proposal_hazard_agnostic_margin_bias", "target": "projects_track_3_crusoe_c_proposal_firebreak", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "projects/track-3-crusoe/c/proposal.md", "source_location": null, "weight": 1.0}, {"source": "projects_track_3_crusoe_c_proposal_two_call_patterns", "target": "projects_track_3_crusoe_c_proposal_firebreak", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "projects/track-3-crus